# GovCA Full Stack — Environment Configuration
# Copy to .env and fill in all values before running

# ── Flask ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
FLASK_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=strong-db-password-here
DATABASE_URL=postgresql://govca:${DB_PASSWORD}@postgres:5432/govca

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── SMTP email ────────────────────────────────────────────────────────────────
MAIL_SERVER=smtp.govca.rw
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=noreply@govca.rw
MAIL_PASSWORD=your-smtp-password

# ── mTLS certificates ─────────────────────────────────────────────────────────
# Generate with: bash scripts/gen_certs.sh
MTLS_CA_CERT=certs/ca/ca.crt
MTLS_SERVER_CERT=certs/server/server.crt
MTLS_SERVER_KEY=certs/server/server.key
VERIFY_CLIENT_CERT=true

# ── Image detection thresholds ────────────────────────────────────────────────
BLUR_THRESHOLD=80.0
MIN_BRIGHTNESS=40.0
MAX_BRIGHTNESS=220.0
EYE_OPEN_RATIO=0.22
EAR_EDGE_MARGIN=0.04
FACE_MIN_COVERAGE=0.82
FACE_CONFIDENCE=0.70
MAX_UPLOAD_MB=5

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── GitHub Actions secrets (set in repo Settings → Secrets) ──────────────────
# PROD_HOST       = production server IP
# PROD_USER       = deploy SSH username
# PROD_SSH_KEY    = private key for SSH deployment
