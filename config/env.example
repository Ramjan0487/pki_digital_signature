# GovCA Image Validation — Environment Configuration
# Copy this file to .env and fill in real values

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# SMTP (email delivery)
SMTP_HOST=smtp.govca.rw
SMTP_PORT=465
SMTP_USER=noreply@govca.rw
SMTP_PASSWORD=your_smtp_password_here

# GovCA Auth API (if proxying login)
GOVCA_AUTH_URL=https://www.govca.rw/auth/api/login
GOVCA_API_KEY=your_api_key_here

# Service
PORT=8000
ENVIRONMENT=production
